      <a href="/astrology">Astrology &amp; Zodiac</a>
      <a href="/daily-tarot">Witch's Journal</a>
    </div>
  </nav>

  <slot />

  <footer>
    <div class="footer-inner">
      <div class="footer-col">
        <h4>CONNECT</h4>
        <p class="footer-heading"><strong>Join the Circle</strong></p>
        <p>Subscribe for moon phase updates, tarot wisdom, and spiritual insights — plus invitations to our goddess retreats &amp; rituals.</p>
        <div class="social-icons">
          <a href="https://www.instagram.com/vanessahylande/" target="_blank" rel="noopener" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
