  <script src="/scripts/mmenu-light.js" is:inline></script>
  <script is:inline>
    // Desktop: mega menu hover behavior
    document.querySelectorAll('.desktop-nav .mega-categories').forEach(catGroup => {
      catGroup.querySelectorAll('.mega-cat').forEach(cat => {
        cat.addEventListener('mouseenter', () => {
          const panel = cat.getAttribute('data-panel');
          const container = catGroup.parentElement;
          container.querySelectorAll(':scope > .mega-panel').forEach(p => p.classList.remove('active'));
          container.querySelector('#panel-' + panel)?.classList.add('active');
          catGroup.querySelectorAll('.mega-cat').forEach(c => c.classList.remove('active'));
          cat.classList.add('active');
        });
      });
    });
    document.querySelectorAll('.desktop-nav #panel-minor').forEach(minor => {
      minor.addEventListener('mouseenter', () => {
        const cats = minor.querySelector('.suit-cats');
        if (cats && !cats.querySelector('.mega-cat.active')) {
          cats.querySelector('.mega-cat')?.classList.add('active');
          minor.querySelector('.suit-panel')?.classList.add('active');
        }
      });
    });
    document.querySelectorAll('.desktop-nav .dropdown-mega').forEach(menu => {
      menu.addEventListener('mouseenter', () => {
        if (!menu.querySelector(':scope > .mega-categories > .mega-cat.active')) {
          menu.querySelector(':scope > .mega-categories > .mega-cat')?.classList.add('active');
          menu.querySelector(':scope > .mega-panel')?.classList.add('active');
        }
      });
    });

    // Mobile: mmenu-light
    var menu = new MmenuLight(document.querySelector('#mobile-nav'), '(max-width: 768px)');
    var navigator = menu.navigation({ title: 'Tarot Flower', theme: 'light' });
    var drawer = menu.offcanvas({ position: 'left' });
    document.querySelector('a.hamburger')?.addEventListener('click', (e) => {
      e.preventDefault();
      drawer.open();
    });
  </script>
</body>
</html>
