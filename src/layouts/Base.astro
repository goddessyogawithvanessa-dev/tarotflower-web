---
interface Props {
  title: string;
  description?: string;
  image?: string;
  showBanner?: boolean;
}

const { title, description = '', image = '', showBanner = true } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = image ? new URL(image, Astro.site) : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL.href} />
  <link rel="icon" type="image/jpeg" sizes="32x32" href="/favicon.jpg" />
  <link rel="icon" type="image/jpeg" sizes="192x192" href="/favicon-192x192.jpg" />
  {description && <meta name="description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  {socialImageURL && <meta property="og:image" content={socialImageURL.href} />}
  <meta property="og:site_name" content="Tarot Flower" />
  <meta name="twitter:card" content={socialImageURL ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  {socialImageURL && <meta name="twitter:image" content={socialImageURL.href} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tangerine:wght@400;700&family=Aboreto&family=Quattrocento:wght@400;700&family=Cormorant+Garamond:wght@300;400;500;600&display=swap" rel="stylesheet" />
