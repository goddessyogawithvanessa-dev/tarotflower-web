        <a href="/minor-arcana">Minor Arcana</a>
        <a href="/moon-magic-spells">Spells &amp; Rituals</a>
        <a href="/astrology">Astrology</a>
        <a href="/free-tarot-card-readings">Free Tarot Readings</a>
      </div>
      <div class="footer-col">
        <h4>More</h4>
        <a href="/goddess-yoga">Goddess Yoga</a>
        <a href="/goddess-yoga-retreats">Retreats</a>
        <a href="/affirmations">Affirmations</a>
        <a href="/sound-bath-meditations">Sound Bath Meditations</a>
        <a href="/shop">Shop</a>
        <a href="/contact">Contact</a>
      </div>
      <div class="footer-col">
        <h4>Connect</h4>
        <a href="https://www.instagram.com/vanessahylande/" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.pinterest.com/tarotflower/" target="_blank" rel="noopener">Pinterest</a>
        <a href="https://www.youtube.com/@vanessahylande" target="_blank" rel="noopener">YouTube</a>
        <a href="https://www.tiktok.com/@vanessahylande" target="_blank" rel="noopener">TikTok</a>
        <a href="https://www.facebook.com/tarotflower" target="_blank" rel="noopener">Facebook</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Tarot Flower &middot; Site by Vanessa Hylande</p>
    </div>
  </footer>
</body>
</html>
