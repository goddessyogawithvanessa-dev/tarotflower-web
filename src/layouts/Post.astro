---
const { title, date, categories = [], original_url, seo_title, seo_description } = Astro.props;
const displayDate = new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const cats = categories.join(', ');
const pageTitle = seo_title || title;
const metaDesc = seo_description || '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  {metaDesc && <meta name="description" content={metaDesc} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Quattrocento:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <div class="banner">
    <img src="https://tarotflower.com/wp-content/uploads/2024/03/TF-Header-2024-Dandelion.jpeg" alt="Tarot Flower" />
  </div>
  <nav>
    <a href="/">Home</a>
    <a href="#">Tarot Card Readings</a>
    <a href="#">Tarot Card Meanings</a>
    <a href="#">Spells &amp; Rituals</a>
    <a href="#">Astrology &amp; Zodiac</a>
    <a href="#">Witch's Journal</a>
  </nav>
  <div class="container">
    <h1>{title}</h1>
    <div class="meta">
      <span>{displayDate}</span>
      {cats && <span>{cats}</span>}
      {original_url && <span><a href={original_url} target="_blank">View original &nearr;</a></span>}
    </div>
    <div class="content clearfix">
      <slot />
    </div>
  </div>
</body>
</html>
