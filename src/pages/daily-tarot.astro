const fallbackImages: Record<string, string> = {
  'divine-feminine-affirmations-for-kundalini-awakening-and-goddess-embodiment': '/images/2024/02/Divine-Feminine-Affirmations-blog-art.jpeg',
  'sound-bath-meditation-12-12-portal-and-the-sagittarius-new-moon': '/images/2023/12/Screen-Shot-2023-12-13-at-10.18.52-AM-400x250.jpg',
  'music-for-ritual-and-meditationmoon-magic-for-the-full-moon-in-virgo-2023': '/images/2023/03/Screen-Shot-2023-03-06-at-3.43.13-PM-400x250.jpg',
};

const cardPosts = cardSlugs
  .map(slug => posts.find(p => p.data.slug === slug))
  .filter(Boolean);

function extractImage(body: string): string {
  const match = body.match(/!\[([^\]]*)\]\((\/[^)]+)\)/);
  return match ? match[2] : '';
}

function extractExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#') || trimmed.startsWith('!') || trimmed.startsWith('*') && trimmed.length < 30) continue;
    const clean = trimmed.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/\*\*([^*]+)\*\*/g, '$1').replace(/\*([^*]+)\*/g, '$1');
    if (clean.length > 30) return clean.length > 120 ? clean.slice(0, 117) + '...' : clean;
  }
  return '';
}

function formatCategories(cats: string[]): string {
  return cats
    .filter(c => c !== 'daily-tarot')
    .map(c => c.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '))
    .join(', ');
}
---
<Base
  title={page?.data.seo_title || "The Witch's Journal – Tarot, Rituals & Reflections"}
  description={page?.data.seo_description || ''}
>
  <div class="container">
    <div class="content clearfix">
      <h1>The Witch's Journal</h1>

      <p><strong>Welcome to the Witch's Journal</strong></p>

      <p>This is more than a blog — it's a living archive of magic, memory, and transformation. The Witch's Journal is where raw reflections meet ritual, where the tarot becomes a mirror, and where lunar cycles guide the rhythm of life. Every post you'll find here was born from practice, prayer, insight, or experience — woven from moonlight and mystery into words that resonate with seekers like you.</p>

      <details class="read-more-toggle">
        <summary>Read More</summary>
        <div class="read-more-content">
          <p>You won't find perfection here. You'll find presence. The kind that only comes from walking the path day by day, from reading the cards not just to predict, but to <em>remember</em>. This is a place for the sacred in-between: the moments before the spell is cast, the silence after the tarot is pulled, the whispers you only hear when you slow down enough to listen.</p>
          <p>Most of the entries you'll discover in this space are reflections on the current energy — seasonal shifts, new and full moon rituals, channeled tarot spreads, astrology insights, and twin flame musings. It's where I share what I've learned, what I'm still learning, and what Spirit keeps teaching me. You may find old entries that feel eerily relevant — that's the beauty of a spiral path. We return again and again, but with deeper awareness each time.</p>
          <p>Whether you're new to your path or well into your witchy renaissance, this journal is for you. Not to copy — but to <em>awaken</em> your own magic. The entries here are invitations. Read a ritual, try a spread, light a candle, and see what comes through. Then, take what resonates and leave the rest. There are no rules in the Witch's Journal — only rhythm and intention.</p>
          <p>So where to begin? Start where you're drawn. If you're in the mood for lunar magic, explore the moon rituals. Feeling the ache of the twin flame journey? Those entries may be calling you. Curious about psychic abilities, energetic hygiene, or spellwork? It's all in here — layered, honest, and unfolding in real time.</p>
          <p>This is also where my voice becomes more personal. While Tarot Flower is a sacred library for learning the craft, the Witch's Journal is where you meet me — the woman behind the altar, the mystic at the piano, the mother, the teacher, the traveler, the vessel. You'll see the connections between the rituals and the retreats, between the Moonlight Circle and the cards, between healing and embodiment.</p>
          <p>If something you read sparks something inside you — follow it. That spark is your inner flame. And if you feel the call to go deeper, to practice in community, or to awaken your inner goddess, then I invite you to step beyond the page and into sacred space with me.</p>
          <p>The Witch's Journal is only the beginning.</p>
        </div>
      </details>
    </div>

    <section class="zodiac-grid">
      {cardPosts.map(post => {
        const img = fallbackImages[post!.data.slug] || extractImage(post!.body || '');
        const excerpt = extractExcerpt(post!.body || '');
        const displayDate = new Date(post!.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        const cats = post!.data.categories || [];
        return (
          <a href={`/${post!.data.slug}`} class="zodiac-card">
            {img && <div class="zodiac-img"><img src={img} alt={post!.data.title} loading="lazy" /></div>}
            <div class="zodiac-info">
              <h3>{post!.data.title}</h3>
              <span class="zodiac-meta">by Vanessa Hylande | {displayDate} | {formatCategories(cats)}</span>
              {excerpt && <p class="zodiac-excerpt">{excerpt}</p>}
            </div>
          </a>
        );
      })}
    </section>

    <div class="content clearfix">
      <p>At Daily Tarot we love to talk about the current energies and bring you sage advice and inspiration through our free tarot card readings. These readings are general, but will always offer some beautiful and inspirational messages from the major arcana, minor arcana and oracle cards. We always consider the current astrology to give you the most complete assessment of the energetic landscape we are currently in.</p>
      <p>Our Tarot Flower Daily Tarot blog will not only discuss traditional tarot, but will also explore ways that you can embody the tarot. This will enable you to begin manifesting abundance and flow in your life, by putting the lessons of the tarot into practice. It's not always enough to understand things with the mind. Sometimes we need guidance on how to put our spirituality into practice.</p>
      <p>If you'd like to learn more about embodiment, join us at our beautiful <a href="https://goddess-yoga-retreat.com/glow-up-with-goddess-yoga/">Goddess Yoga Retreats</a>. Especially if you are an artist and prefer to learn in a holistic way, you have come to the right place. So, if you are ready to move beyond simply learning the <a href="/tarot-card-meanings">tarot card meanings</a>, read on! Enjoy!</p>
    </div>
  </div>
</Base>
