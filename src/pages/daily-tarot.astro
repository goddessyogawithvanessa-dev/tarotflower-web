---
import Base from '../layouts/Base.astro';
import JournalIndex from '../components/JournalIndex.astro';
import { getCollection } from 'astro:content';
import {
  createJournalEntries,
  getCategoryEntries,
  getJournalCategory,
  getShelfEntries,
  journalCategories,
  type JournalCategorySlug,
} from '../lib/journal';

const posts = await getCollection('posts');
const page = posts.find((post) => post.data.slug === 'daily-tarot');
const entries = createJournalEntries(posts);
const featuredEntries = entries
  .filter((entry) => entry.featured)
  .sort((a, b) => a.featureOrder - b.featureOrder);

const shelfSlugs: JournalCategorySlug[] = [
  'embodiment',
  'embodying-tarot',
  'moon-magic',
  'cosmic-weather',
  'twin-flames',
  'affirmations',
  'mythology',
];
const shelves = shelfSlugs.map((slug) => ({
  category: getJournalCategory(slug),
  entries: getShelfEntries(entries, slug, 3),
}));

const personalEntries = getCategoryEntries(entries, 'vanessas-grimoire')
  .sort((a, b) => {
    if (a.featured !== b.featured) return a.featured ? -1 : 1;
    return b.wordCount - a.wordCount || a.title.localeCompare(b.title);
  })
  .slice(0, 5);

const gatewayCount = (slug: JournalCategorySlug) => getCategoryEntries(entries, slug).length;
const featuredCategory = (slug: JournalCategorySlug) => getJournalCategory(slug);
---

<Base
  title={page?.data.seo_title || "The Witch's Journal – Tarot, Rituals & Reflections"}
  description={page?.data.seo_description || 'Enter the living library of Tarot Flower: stories, rituals, mythology, embodiment and spiritual wisdom.'}
  image="/images/2023/10/raven.jpg"
  imageAlt="A raven beside a flower-crowned woman in mystical Tarot Flower artwork"
  imageWidth={1024}
  imageHeight={1024}
>
  <main class="journal-page">
    <section class="journal-hero">
      <div class="journal-hero-copy">
        <p class="journal-eyebrow">A Living Library</p>
        <h1>The Witch's Journal</h1>
        <p class="journal-hero-lede">Stories, rituals, mythology and wisdom for the path between knowing and becoming.</p>
        <div class="journal-hero-introduction">
          <p>The Witch's Journal is a living library of magic, memory and transformation. Here, personal stories rest beside lunar rituals, ancient goddesses speak through modern lives, and the wisdom of the body meets the language of the stars.</p>
          <p>You do not need to begin at the beginning. Follow what catches your eye, open the door that calls to you, and allow one idea to lead unexpectedly into another.</p>
        </div>
      </div>
      <figure class="journal-hero-art">
        <img
          src="/images/2023/10/raven.jpg"
          alt="A raven beside a flower-crowned woman in mystical Tarot Flower artwork"
          width="1024"
          height="1024"
          decoding="async"
        />
      </figure>
    </section>

    <section class="journal-doorways" aria-labelledby="journal-doorways-title">
      <div class="journal-section-heading journal-doorways-heading">
        <p class="journal-eyebrow">Choose a room</p>
        <h2 id="journal-doorways-title">Where would you like to wonder today?</h2>
        <p>Choose a doorway, or follow the one that is choosing you.</p>
      </div>

      <div class="journal-doorway-grid">
        {journalCategories.map((category, index) => (
          <a
            class:list={['journal-doorway', `journal-doorway-${category.tone}`, { 'journal-doorway-large': index === 0 || index === 2 }]}
            href={`/daily-tarot?room=${category.slug}#complete-index`}
            data-journal-room-link={category.slug}
          >
            <img
              src={category.image}
              alt={category.imageAlt}
              width={category.imageWidth}
              height={category.imageHeight}
              loading="lazy"
              decoding="async"
            />
            <span class="journal-doorway-shade" aria-hidden="true"></span>
            <span class="journal-doorway-copy">
              <small>{category.eyebrow}</small>
              <strong>{category.label}</strong>
              <span><b>{category.question}</b>{category.description}</span>
              <em>{gatewayCount(category.slug)} writings · Enter this room</em>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="journal-begin" aria-labelledby="journal-begin-title">
      <div class="journal-section-heading">
        <p class="journal-eyebrow">Begin with a Doorway</p>
        <h2 id="journal-begin-title">Some stories find us first</h2>
        <p>Five enduring paths into the questions that live throughout the Journal.</p>
      </div>

      <div class="journal-feature-layout">
        {featuredEntries.map((entry, index) => {
          const category = featuredCategory(entry.category);
          const artwork = entry.featureImage || {
            src: category.image,
            alt: category.imageAlt,
            width: category.imageWidth,
            height: category.imageHeight,
          };
          return (
            <article class:list={['journal-feature', { 'journal-feature-primary': index === 0 }]}>
              <a href={`/${entry.slug}`} class="journal-feature-image">
                <img
                  src={artwork.src}
                  alt={artwork.alt}
                  width={artwork.width}
                  height={artwork.height}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </a>
              <div class="journal-feature-copy">
                <p>{entry.categoryLabel}</p>
                <h3><a href={`/${entry.slug}`}>{entry.title}</a></h3>
                <p>{entry.excerpt}</p>
                <a href={`/${entry.slug}`}>Open this volume <span aria-hidden="true">→</span></a>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <section class="journal-shelves" aria-labelledby="journal-shelves-title">
      <div class="journal-section-heading">
        <p class="journal-eyebrow">Shelves of Living Wisdom</p>
        <h2 id="journal-shelves-title">Follow the thread that glimmers</h2>
        <p>Each shelf holds a different way of listening—to the body, the sky, the heart and the unseen.</p>
      </div>

      <div class="journal-shelf-list">
        {shelves.map(({ category, entries: shelfEntries }, shelfIndex) => (
          <section class:list={['journal-shelf', { 'journal-shelf-reverse': shelfIndex % 2 === 1 }]} id={`shelf-${category.slug}`}>
            <div class="journal-shelf-art">
              <img
                src={category.image}
                alt={category.imageAlt}
                width={category.imageWidth}
                height={category.imageHeight}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="journal-shelf-content">
              <p class="journal-eyebrow">{category.eyebrow}</p>
              <h3>{category.label}</h3>
              <p><strong>{category.question}</strong> {category.description}</p>
              <ol>
                {shelfEntries.map((entry) => (
                  <li>
                    <a href={`/${entry.slug}`}>
                      <span>{entry.title}</span>
                      <small>{entry.excerpt}</small>
                    </a>
                  </li>
                ))}
              </ol>
              <a
                class="journal-room-link"
                href={`/daily-tarot?room=${category.slug}#complete-index`}
                data-journal-room-link={category.slug}
              >Browse the complete room <span aria-hidden="true">→</span></a>
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="journal-personal" aria-labelledby="journal-personal-title">
      <div class="journal-personal-intro">
        <p class="journal-eyebrow">A temporary title</p>
        <h2 id="journal-personal-title">Vanessa's Grimoire</h2>
        <p>Stories written from the places where life, symbol and spirit meet. This is the intimate room of the library: personal essays, poems, visions and remembered thresholds.</p>
      </div>
      <div class="journal-personal-layout">
        {personalEntries.map((entry, index) => (
          <article class:list={['journal-personal-entry', { 'journal-personal-feature': index === 0 }]}>
            {index === 0 && (
              <img
                src="/images/2023/10/raven.jpg"
                alt="A raven beside a flower-crowned woman in mystical Tarot Flower artwork"
                width="1024"
                height="1024"
                loading="lazy"
                decoding="async"
              />
            )}
            <div>
              <p>{index === 0 ? 'From Vanessa’s desk' : 'A personal writing'}</p>
              <h3><a href={`/${entry.slug}`}>{entry.title}</a></h3>
              <p>{entry.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
      <a
        class="journal-room-link journal-personal-link"
        href="/daily-tarot?room=vanessas-grimoire#complete-index"
        data-journal-room-link="vanessas-grimoire"
      >Enter the complete grimoire <span aria-hidden="true">→</span></a>
    </section>

    <section class="journal-tarot-bridge" aria-labelledby="journal-tarot-title">
      <div class="journal-tarot-copy">
        <p class="journal-eyebrow">A neighboring wing</p>
        <h2 id="journal-tarot-title">When you are ready for the cards</h2>
        <p>The Witch's Journal follows living questions wherever they lead. The Tarot Library offers a more structured path through the cards, archetypes and meanings.</p>
      </div>
      <nav class="journal-tarot-links" aria-label="Continue into the Tarot Library">
        <a href="/tarot-card-meanings"><span>Begin the study</span><strong>Tarot Card Meanings</strong></a>
        <a href="/major-arcana-2"><span>Walk the archetypal path</span><strong>Major Arcana</strong></a>
        <a href="/minor-arcana"><span>Meet the everyday mysteries</span><strong>Minor Arcana</strong></a>
        <a href="/readings-with-vanessa"><span>Receive personal reflection</span><strong>Tarot Readings with Vanessa</strong></a>
      </nav>
    </section>

    <JournalIndex entries={entries} currentPage={1} />
  </main>
</Base>
