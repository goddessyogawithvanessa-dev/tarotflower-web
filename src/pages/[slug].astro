---
import { getCollection, render } from 'astro:content';
import Post from '../layouts/Post.astro';

export async function getStaticPaths() {
  const dedicatedPages = ['astrology', 'free-tarot-card-readings', 'tarot-card-readings', 'moon-magic-spells', 'tarot-card-meanings', 'contact', 'daily-tarot', 'shop'];
  const posts = await getCollection('posts');
  return posts
    .filter(post => !dedicatedPages.includes(post.data.slug))
    .map(post => ({
      params: { slug: post.data.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Post {...post.data}>
  <Content />
</Post>
