---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const products = await getCollection('products');
const sorted = products.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base title="Shop | Tarot Flower" description="Tarot readings, retreats, and spiritual services from Tarot Flower.">
  <div class="container">
    <h1>Shop</h1>
    <div class="product-grid">
      {sorted.map(product => (
        <a href={`/product/${product.data.slug}`} class="product-card">
          {product.data.image ? (
            <img src={product.data.image} alt={product.data.title} class="product-card-img" />
          ) : (
            <div class="product-card-placeholder">
              <i class="fa-solid fa-sun"></i>
            </div>
          )}
          <div class="product-card-body">
            <h2>{product.data.title}</h2>
            {product.data.seo_description && (
              <p>{product.data.seo_description}</p>
            )}
            {product.data.price && (
              <span class="product-card-price">${product.data.price}</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
