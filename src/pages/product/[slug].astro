---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const { title, price, stripe_link, seo_title, seo_description } = product.data;
---
<Base title={seo_title || title} description={seo_description || ''}>
  <div class="container">
    <h1>{title}</h1>
    {price && <p class="product-price">${price}</p>}
    <div class="content clearfix">
      <Content />
    </div>
    {stripe_link && (
      <a href={stripe_link} class="buy-button" target="_blank" rel="noopener">Buy Now</a>
    )}
  </div>
</Base>
