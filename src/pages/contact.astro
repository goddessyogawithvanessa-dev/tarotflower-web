---
import Base from '../layouts/Base.astro';
---
<Base title="Contact | Tarot Flower" description="Have a question about tarot, retreats, or mystical collaborations? Get in touch.">
  <div class="container">
    <h1 class="contact-title">Get in Touch</h1>

    <blockquote class="contact-quote">
      <p>Have a question about tarot, retreats, or mystical collaborations?<br />
      I'm always happy to hear from kindred spirits.</p>
      <p>Send a message below, and I'll respond as soon as I can</p>
    </blockquote>

    <form class="contact-form" action="/api/contact" method="POST">
      <div class="contact-row">
        <input type="text" name="name" placeholder="Name" required />
        <input type="email" name="email" placeholder="Email Address" required />
      </div>
      <textarea name="message" placeholder="Message" rows="8" required></textarea>
      <div class="contact-bottom">
        <div class="contact-captcha">
          <span id="captcha-q"></span>
          <input type="number" name="captcha" id="captcha-answer" required />
        </div>
        <button type="submit" class="contact-btn">Send Message</button>
      </div>
    </form>
  </div>

  <script>
    const a = Math.floor(Math.random() * 10);
    const b = Math.floor(Math.random() * 10);
    document.getElementById('captcha-q')!.textContent = `${a} + ${b} = `;
    const form = document.querySelector('.contact-form') as HTMLFormElement;
    form.addEventListener('submit', (e) => {
      const answer = parseInt((document.getElementById('captcha-answer') as HTMLInputElement).value);
      if (answer !== a + b) {
        e.preventDefault();
        alert('Incorrect answer, please try again.');
      }
    });
  </script>
</Base>
