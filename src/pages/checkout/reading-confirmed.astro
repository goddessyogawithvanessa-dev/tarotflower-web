---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Reading Confirmed | Tarot Flower"
  description="Your 60-minute online tarot reading with Vanessa has been confirmed."
>
  <main class="checkout-page checkout-result-page">
    <section class="checkout-result container" aria-labelledby="checkout-success-title">
      <p class="checkout-result-kicker">Payment received</p>
      <h1 id="checkout-success-title">Your Reading Is Confirmed</h1>
      <p>Thank you for booking a reading with Vanessa.</p>
      <p>Stripe will send a receipt to the email address used at checkout. Vanessa will contact you at that same address to arrange your 60-minute online reading.</p>
      <a class="shop-button" href="/shop/">Return to the Shop</a>
    </section>
  </main>
</Base>
