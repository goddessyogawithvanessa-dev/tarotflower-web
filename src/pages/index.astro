---
import Base from '../layouts/Base.astro';

const majorArcana = [
  { name: 'The Fool', slug: 'the-fool-tarot' },
  { name: 'The Magician', slug: 'the-magician-tarot' },
  { name: 'The High Priestess', slug: 'the-high-priestess-tarot' },
  { name: 'The Empress', slug: 'the-empress-tarot' },
  { name: 'The Emperor', slug: 'the-emperor-tarot' },
  { name: 'The Hierophant', slug: 'the-hierophant-tarot' },
  { name: 'The Lovers', slug: 'the-lovers-tarot' },
  { name: 'The Chariot', slug: 'the-chariot-tarot' },
  { name: 'Strength', slug: 'strength-tarot' },
  { name: 'The Hermit', slug: 'the-hermit-tarot' },
  { name: 'The Wheel of Fortune', slug: 'the-wheel-of-fortune-tarot' },
  { name: 'Justice', slug: 'justice-tarot' },
  { name: 'The Hanged Man', slug: 'the-hanged-man-tarot' },
  { name: 'Death', slug: 'death-tarot' },
  { name: 'Temperance', slug: 'temperance-tarot' },
  { name: 'The Devil', slug: 'the-devil-tarot' },
  { name: 'The Tower', slug: 'the-tower-tarot' },
  { name: 'The Star', slug: 'the-star-tarot' },
  { name: 'The Moon', slug: 'the-moon-tarot' },
  { name: 'The Sun', slug: 'the-sun-tarot' },
  { name: 'Judgement', slug: 'judgement-tarot' },
  { name: 'The World', slug: 'the-world-tarot' },
];

const suitImg = '/images/2020/12/IMG_20201215_123548-scaled.jpg';
const suits = [
  { name: 'Pentacles', slug: 'pentacles-tarot', img: suitImg, cards: ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] },
  { name: 'Wands', slug: 'wands-tarot', img: suitImg, cards: ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] },
  { name: 'Swords', slug: 'swords-tarot', img: suitImg, cards: ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] },
  { name: 'Cups', slug: 'cups-tarot', img: suitImg, cards: ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] },
];

const goddessEmbodimentGuideContent = [
  {
    cover: '/images/goddess-embodiment-guide-cover.jpg',
    coverAlt: 'Goddess Embodiment Ten Steps To Embody the Goddess guide cover',
  },
];
const digitalRituals = [
  {
    title: 'Ignite Your Inner Fire',
    support: 'A digital ritual for courage & confidence',
    image: '/images/digital-rituals/step-into-the-fire/elemental-rituals-header.jpg',
    imageAlt: 'Fire goddess beneath a golden moon, surrounded by flames and flowers',
    href: '/step-into-the-fire',
    cta: 'Ignite',
    crop: 'fire',
  },
  {
    title: 'Flow with the Goddess',
    support: 'A digital ritual for healing & sensuality',
    image: '/images/digital-rituals/flow-like-the-goddess/water-goddess-banner-ritual.jpg',
    imageAlt: 'Water goddess flowing beneath the moon among golden flowers and fish',
    href: '/flow-like-the-goddess',
    cta: 'Flow',
    crop: 'water',
  },
  {
    title: 'Awaken the Element of Air',
    support: 'A digital ritual for clarity & intuition',
    image: '/images/digital-rituals/awaken-the-element-of-air/air-goddess-header-web.jpg',
    imageAlt: 'Air goddess with luminous wings beneath a golden sky',
    href: '/awaken-the-element-of-air',
    cta: 'Breathe',
    crop: 'air',
  },
  {
    title: 'Root Into the Earth',
    support: 'A digital ritual for stability & belonging',
    image: '/images/digital-rituals/root-into-the-earth/earth-goddess-banner.jpg',
    imageAlt: 'Earth goddess beneath the moon in a dark enchanted forest',
    href: '/root-into-the-earth',
    cta: 'Ground',
    crop: 'earth',
  },
];
const sacredBecomingCoachingContent = [
  {
    portrait: '/images/homepage/vanessa-hylande-sacred-becoming-960.png',
    portraitSrcset: '/images/homepage/vanessa-hylande-sacred-becoming-480.png 480w, /images/homepage/vanessa-hylande-sacred-becoming-720.png 720w, /images/homepage/vanessa-hylande-sacred-becoming-960.png 960w, /images/homepage/vanessa-hylande-sacred-becoming-1324.png 1324w',
    portraitSizes: '(max-width: 768px) calc(100vw - 36px), min(43vw, 493px)',
    portraitAlt: 'Vanessa Hylande for Sacred Becoming coaching',
  },
];
const sacredBecomingOracleDeckContent = [
  {
    artwork: '/images/homepage/07_creation.png.png',
    artworkAlt: 'Creation card artwork from The Sacred Becoming Oracle',
  },
];
const contactApiBase = 'https://tarotflower-web-dev.embodiedgoddesses.workers.dev';

function cardSlug(rank: string, suit: string) {
  return `${rank.toLowerCase()}-of-${suit.toLowerCase()}-tarot`;
}
---
<Base title="Tarot Flower – Learn Tarot Online with Meaningful Insight" description="A modern guide to learn tarot online! Discover intuitive card meanings, spreads, rituals, and spiritual wisdom through the sacred art of tarot.">
  <div class="container homepage">
    <header class="homepage-title">
      <h1>Tarot Flower</h1>
      <p>Unlock the Magic of Tarot, Astrology, and Ritual.</p>
    </header>

    <section class="homepage-introduction" aria-label="Welcome to Tarot Flower">
      <div class="homepage-introduction-copy">
        <span class="homepage-introduction-quote" aria-hidden="true">“</span>
        <p>Welcome, beautiful soul. ✨ You’ve arrived at Tarot Flower — a sanctuary for seekers, mystics, and modern goddesses who are ready to deepen their connection with tarot, astrology, and spiritual ritual.</p>
        <p>Whether you’re just starting your journey or you’ve been walking the path for years, I created this space for you.</p>
        <p class="homepage-introduction-signature">— Vanessa</p>
      </div>
      <div class="homepage-introduction-photo">
        <img src="/images/homepage/vanessa-hooded-tarot.png" alt="Vanessa Hylande holding a tarot card" />
      </div>
    </section>

    {goddessEmbodimentGuideContent.length > 0 && (
      <section id="homepage-goddess-embodiment-guide" class="goddess-guide-section">
        {goddessEmbodimentGuideContent.map(({ cover, coverAlt }) => (
          <div class="goddess-guide">
            <div class="goddess-guide-cover">
              <img src={cover} alt={coverAlt} loading="lazy" />
            </div>
            <div class="goddess-guide-copy">
              <p class="goddess-guide-eyebrow">Your Free Gift</p>
              <h2>The Goddess Embodiment Guide</h2>
              <p class="goddess-guide-support">The goddess is a symbol of your own becoming.</p>
              <p>Discover how tarot, ritual, reflection, movement, and embodiment can become tools for self-discovery, healing, and lasting transformation.</p>
              <p class="goddess-guide-closing">Enjoy your free guide.</p>
              <form class="goddess-guide-form" action="/10-steps-to-embody-the-goddess-free-download" method="GET">
                <button type="submit">Download the Guide</button>
              </form>
            </div>
          </div>
        ))}
      </section>
    )}

    <section id="homepage-digital-rituals" class="homepage-digital-rituals">
      <div class="homepage-digital-rituals-intro">
        <h2>Digital Rituals</h2>
        <p class="homepage-digital-rituals-subheading">Elemental practices for your becoming</p>
        <p>A collection of digital rituals for courage, healing, clarity, and grounding.</p>
        <p class="homepage-digital-rituals-invitation">Choose the element that calls to you.</p>
        <p class="homepage-digital-rituals-ornament" aria-hidden="true">☽⋆˚｡𖤓｡˚⋆☾</p>
      </div>

      <div class="homepage-digital-ritual-features" aria-label="Every Digital Ritual includes">
        <div>
          <i class="fa-solid fa-person-praying" aria-hidden="true"></i>
          <span>Guided Practices</span>
        </div>
        <div>
          <i class="fa-solid fa-music" aria-hidden="true"></i>
          <span>Original Music</span>
        </div>
        <div>
          <i class="fa-solid fa-moon" aria-hidden="true"></i>
          <span>Meditation</span>
        </div>
        <div>
          <i class="fa-solid fa-seedling" aria-hidden="true"></i>
          <span>Deep Inner Work</span>
        </div>
      </div>

      <div class="homepage-digital-ritual-grid">
        {digitalRituals.map(({ title, support, image, imageAlt, href, cta, crop }) => (
          <article class={`homepage-digital-ritual homepage-digital-ritual--${crop}`}>
            <a class="homepage-digital-ritual-image" href={href}>
              <img src={image} alt={imageAlt} loading="lazy" />
            </a>
            <h3><a href={href}>{title}</a></h3>
            <p>{support}</p>
            <a class="digital-ritual-button" href={href}>{cta}</a>
          </article>
        ))}
      </div>
    </section>

    {sacredBecomingCoachingContent.length > 0 && (
      <section id="homepage-sacred-becoming-coaching" class="sacred-becoming-section">
        {sacredBecomingCoachingContent.map(({ portrait, portraitSrcset, portraitSizes, portraitAlt }) => (
          <div class="sacred-becoming">
            <div class="sacred-becoming-portrait">
              <img src={portrait} srcset={portraitSrcset} sizes={portraitSizes} alt={portraitAlt} loading="lazy" />
            </div>
            <div class="sacred-becoming-copy">
              <p class="sacred-becoming-kicker">Sacred Becoming</p>
              <h2>Are you <em>becoming</em>... or are you stuck?</h2>
              <p class="sacred-becoming-body">Walk beside me, and together we'll build the practices that support the life you want to create.</p>
              <p class="sacred-becoming-pillars">Embodiment &bull; Integration &bull; Creation &bull; Together</p>
              <a class="sacred-becoming-cta" href="/sacred-becoming/mentorship">Discover Sacred Becoming</a>
            </div>
          </div>
        ))}
      </section>
    )}

    {sacredBecomingOracleDeckContent.length > 0 && (
      <section id="homepage-sacred-becoming-oracle" class="sacred-oracle-section">
        {sacredBecomingOracleDeckContent.map(({ artwork, artworkAlt }) => (
          <div class="sacred-oracle">
            <div class="sacred-oracle-art">
              <img src={artwork} alt={artworkAlt} loading="lazy" />
            </div>
            <div class="sacred-oracle-copy">
              <p class="sacred-oracle-eyebrow">COMING SOON</p>
              <h2>The Sacred Becoming Oracle</h2>
              <p>I created this oracle deck while walking my own path of becoming. It was my companion. Now it's my gift to you.</p>
              <p>A companion for reflection, ritual, intuition, and the quiet conversations that continue long after the cards are put away.</p>
              <details class="oracle-waitlist" data-oracle-waitlist>
                <summary class="sacred-oracle-cta">Join the Waitlist</summary>
                <div class="oracle-waitlist-panel">
                  <p>Be the first to hear when The Sacred Becoming Oracle is ready.</p>
                  <form class="oracle-waitlist-form" action={`${contactApiBase}/api/contact`} method="POST" data-oracle-waitlist-form>
                    <input type="text" name="website" tabindex="-1" autocomplete="off" hidden />
                    <input type="hidden" name="message" value="Sacred Becoming Oracle waitlist signup. Please add me to the Oracle launch waitlist." />
                    <label>
                      <span>Name</span>
                      <input type="text" name="name" autocomplete="name" required />
                    </label>
                    <label>
                      <span>Email address</span>
                      <input type="email" name="email" autocomplete="email" required />
                    </label>
                    <label class="oracle-waitlist-consent">
                      <input type="checkbox" name="consent" value="true" required />
                      <span>I agree to receive Sacred Becoming Oracle launch updates by email.</span>
                    </label>
                    <div class="contact-turnstile" data-turnstile-widget></div>
                    <button type="submit">Join the Oracle Waitlist</button>
                    <p class="oracle-waitlist-note">No spam. Just Sacred Becoming Oracle news and launch updates.</p>
                    <p class="oracle-waitlist-status" aria-live="polite"></p>
                  </form>
                </div>
              </details>
            </div>
          </div>
        ))}
      </section>
    )}

    <section id="homepage-tarot-library" class="tarot-library">
      <section class="arcana-section">
        <h2>The Major Arcana</h2>
        <h3 class="arcana-subtitle">The great archetypes of the Tarot</h3>
        <div class="arcana-layout">
          <div class="arcana-left">
            <a href="/major-arcana-2" class="suit-img-link">
              <img src="/images/2021/01/Major-Arcana-e1610542977417.jpg" alt="The Major Arcana tarot cards" />
            </a>
          </div>
          <div class="arcana-right">
            {majorArcana.map(card => (
              <a href={`/${card.slug}`}>{card.name}</a>
            ))}
          </div>
        </div>
      </section>

      <section class="arcana-section">
        <h2>The Minor Arcana</h2>
        <h3 class="arcana-subtitle">The four suits of the Tarot</h3>
        <div class="suits-grid">
          {suits.map(suit => (
            <div class="suit-col">
              <h3 class="suit-title"><a href={`/${suit.slug}`}>{suit.name}</a></h3>
              <a href={`/${suit.slug}`} class="suit-img-link">
                <img src={suit.img} alt={`${suit.name} tarot cards`} loading="lazy" />
              </a>
              <div class="suit-cards">
                {suit.cards.map(rank => (
                  <a href={`/${cardSlug(rank, suit.name)}`}>{rank} of {suit.name}</a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    </section>

  </div>

  <script is:inline>
    const oracleWaitlistApiBase = 'https://tarotflower-web-dev.embodiedgoddesses.workers.dev';

    const oracleTurnstileReady = new Promise((resolve) => {
      if (window.turnstile) {
        resolve(window.turnstile);
        return;
      }

      const existingScript = document.querySelector('script[data-turnstile-api]');
      if (existingScript) {
        existingScript.addEventListener('load', () => resolve(window.turnstile), { once: true });
        return;
      }

      const script = document.createElement('script');
      script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
      script.async = true;
      script.defer = true;
      script.dataset.turnstileApi = 'true';
      script.addEventListener('load', () => resolve(window.turnstile), { once: true });
      document.head.append(script);
    });

    async function connectOracleWaitlist(form) {
      if (form.dataset.connected === 'true') return;
      form.dataset.connected = 'true';

      const status = form.querySelector('.oracle-waitlist-status');
      const submit = form.querySelector('button[type="submit"]');
      const container = form.querySelector('[data-turnstile-widget]');
      let widgetId;

      try {
        const response = await fetch(`${oracleWaitlistApiBase}/api/contact/config`, {
          headers: { Accept: 'application/json' },
        });
        if (!response.ok) throw new Error('Verification configuration unavailable.');
        const config = await response.json();
        const sitekey = config.turnstileSiteKey || config.siteKey || config.turnstile_site_key;
        if (!sitekey) throw new Error('Verification site key unavailable.');
        const turnstile = await oracleTurnstileReady;
        widgetId = turnstile.render(container, { sitekey, action: 'contact' });
      } catch (error) {
        status.textContent = 'Please refresh and try again in a moment.';
        submit.disabled = true;
        return;
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        status.textContent = 'Joining...';
        submit.disabled = true;

        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          const text = await response.text();
          const result = text ? JSON.parse(text) : {};
          if (!response.ok) throw new Error(result.error || 'The signup could not be sent.');
          status.textContent = "You're on the Sacred Becoming Oracle waitlist. Thank you.";
          form.reset();
          window.turnstile.reset(widgetId);
        } catch (error) {
          status.textContent = error.message || 'Please try again in a moment.';
          window.turnstile.reset(widgetId);
        } finally {
          submit.disabled = false;
        }
      });
    }

    document.querySelectorAll('[data-oracle-waitlist]').forEach((waitlist) => {
      waitlist.addEventListener('toggle', () => {
        if (!waitlist.open) return;
        const form = waitlist.querySelector('[data-oracle-waitlist-form]');
        if (form) connectOracleWaitlist(form);
      });
    });
  </script>
</Base>
