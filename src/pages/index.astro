---
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sorted = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Tarot Flower</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Quattrocento:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <div class="banner">
    <img src="https://tarotflower.com/wp-content/uploads/2024/03/TF-Header-2024-Dandelion.jpeg" alt="Tarot Flower" />
  </div>
  <nav>
    <a href="/">Home</a>
    <a href="#">Tarot Card Readings</a>
    <a href="#">Tarot Card Meanings</a>
    <a href="#">Spells &amp; Rituals</a>
    <a href="#">Astrology &amp; Zodiac</a>
    <a href="#">Witch's Journal</a>
  </nav>
  <div class="container">
    <h1>Tarot Flower</h1>
    <p>{sorted.length} posts</p>
    <ul class="index-list">
      {sorted.map(post => (
        <li>
          <a href={`/${post.data.slug}`}>{post.data.title}</a>
          <span class="slug">/{post.data.slug}</span>
        </li>
      ))}
    </ul>
  </div>
</body>
</html>
