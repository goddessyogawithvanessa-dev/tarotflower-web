---
import Base from '../layouts/Base.astro';
import OracleWaitlist from '../components/OracleWaitlist.astro';

const goddessEmbodimentGuideContent = [
  {
    cover: '/images/goddess-embodiment-guide-cover.jpg',
    coverAlt: 'Goddess Embodiment Ten Steps To Embody the Goddess guide cover',
  },
];
const homepageDoorways = [
  {
    title: "The Witch's Journal",
    eyebrow: 'A Living Library',
    invitation: 'Come wonder',
    description: 'Stories, rituals, mythology and wisdom for the path between knowing and becoming.',
    image: '/images/2023/10/raven.jpg',
    imageAlt: 'A raven beside a flower-crowned woman in mystical Tarot Flower artwork',
    width: 1024,
    height: 1024,
    href: '/daily-tarot',
    tone: 'journal',
  },
  {
    title: 'The Tarot Library',
    eyebrow: 'The great archetypes of the Tarot',
    invitation: 'Come learn',
    description: 'Explore the Major Arcana and the four suits of the Tarot.',
    image: '/images/2021/01/Major-Arcana-e1610542977417.jpg',
    imageAlt: 'The Major Arcana tarot cards',
    width: 1200,
    height: 1294,
    href: '/tarot-card-meanings',
    tone: 'tarot',
  },
  {
    title: 'Digital Rituals',
    eyebrow: 'Elemental practices for your becoming',
    invitation: 'Come experience',
    description: 'A collection of digital rituals for courage, healing, clarity, and grounding.',
    image: '/images/digital-rituals/step-into-the-fire/elemental-rituals-header.jpg',
    imageAlt: 'Fire goddess beneath a golden moon, surrounded by flames and flowers',
    width: 1600,
    height: 500,
    href: '/shop',
    tone: 'rituals',
  },
  {
    title: 'Sacred Becoming',
    eyebrow: 'Embodiment · Integration · Creation · Together',
    invitation: 'Come transform',
    description: "Walk beside me, and together we'll build the practices that support the life you want to create.",
    image: '/images/homepage/vanessa-hylande-sacred-becoming-960.png',
    imageAlt: 'Vanessa Hylande for Sacred Becoming mentorship',
    width: 960,
    height: 861,
    href: '/sacred-becoming/mentorship',
    tone: 'becoming',
  },
];
const sacredBecomingOracleDeckContent = [
  {
    artwork: '/images/homepage/07_creation.png.png',
    artworkAlt: 'Creation card artwork from The Sacred Becoming Oracle',
  },
];
---
<Base title="Tarot Flower – Learn Tarot Online with Meaningful Insight" description="A modern guide to learn tarot online! Discover intuitive card meanings, spreads, rituals, and spiritual wisdom through the sacred art of tarot.">
  <div class="container homepage">
    <header class="homepage-title">
      <h1>Tarot Flower</h1>
      <p>Unlock the Magic of Tarot, Astrology, and Ritual.</p>
    </header>

    <section class="homepage-introduction" aria-label="Welcome to Tarot Flower">
      <div class="homepage-introduction-copy">
        <span class="homepage-introduction-quote" aria-hidden="true">“</span>
        <p>Welcome, beautiful soul. ✨ You’ve arrived at Tarot Flower — a sanctuary for seekers, mystics, and modern goddesses who are ready to deepen their connection with tarot, astrology, and spiritual ritual.</p>
        <p>Whether you’re just starting your journey or you’ve been walking the path for years, I created this space for you.</p>
        <p class="homepage-introduction-signature">— Vanessa</p>
      </div>
      <div class="homepage-introduction-photo">
        <img src="/images/homepage/vanessa-hooded-tarot.png" alt="Vanessa Hylande holding a tarot card" width="1254" height="1254" />
      </div>
    </section>

    {goddessEmbodimentGuideContent.length > 0 && (
      <section id="homepage-goddess-embodiment-guide" class="goddess-guide-section">
        {goddessEmbodimentGuideContent.map(({ cover, coverAlt }) => (
          <div class="goddess-guide">
            <div class="goddess-guide-cover">
              <img src={cover} alt={coverAlt} width="1414" height="2000" loading="lazy" decoding="async" />
            </div>
            <div class="goddess-guide-copy">
              <p class="goddess-guide-eyebrow">Your Free Gift</p>
              <h2>The Goddess Embodiment Guide</h2>
              <p class="goddess-guide-support">The goddess is a symbol of your own becoming.</p>
              <p>Discover how tarot, ritual, reflection, movement, and embodiment can become tools for self-discovery, healing, and lasting transformation.</p>
              <p class="goddess-guide-closing">Enjoy your free guide.</p>
              <form class="goddess-guide-form" action="/10-steps-to-embody-the-goddess-free-download" method="GET">
                <button type="submit">Download the Guide</button>
              </form>
            </div>
          </div>
        ))}
      </section>
    )}

    <section class="homepage-doorways" aria-labelledby="homepage-doorways-title">
      <div class="homepage-doorways-intro">
        <p class="homepage-doorways-eyebrow">Tarot Flower</p>
        <h2 id="homepage-doorways-title">Choose your doorway</h2>
        <p>Which room are you walking into?</p>
      </div>

      <div class="homepage-doorways-grid">
        {homepageDoorways.map(({ title, eyebrow, invitation, description, image, imageAlt, width, height, href, tone }) => (
          <a class={`homepage-doorway homepage-doorway--${tone}`} href={href}>
            <img src={image} alt={imageAlt} width={width} height={height} loading="lazy" decoding="async" />
            <span class="homepage-doorway-shade" aria-hidden="true"></span>
            <span class="homepage-doorway-copy">
              <small>{eyebrow}</small>
              <strong>{title}</strong>
              <span>{description}</span>
              <em>{invitation} <span aria-hidden="true">→</span></em>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="homepage-readings" aria-labelledby="homepage-readings-title">
      <div class="homepage-readings-image">
        <img
          src="/images/readings-with-vanessa/vanessa-shuffling-teal-tarot-cards.png"
          alt="Vanessa smiling while shuffling teal tarot cards"
          width="947"
          height="1661"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="homepage-readings-copy">
        <p class="homepage-readings-eyebrow">Tarot Readings</p>
        <h2 id="homepage-readings-title">Readings with Vanessa</h2>
        <p class="homepage-readings-support">Personal tarot readings for clarity, reflection, and guidance.</p>
        <p>A tarot reading is a space to pause, look more deeply, and listen to what is asking for your attention.</p>
        <p>Together, we'll explore the cards, the patterns unfolding around you, and the possibilities available to you now.</p>
        <a class="homepage-reading-button" href="/readings-with-vanessa/">Book a Reading with Vanessa</a>
      </div>
    </section>

    {sacredBecomingOracleDeckContent.length > 0 && (
      <section id="homepage-sacred-becoming-oracle" class="sacred-oracle-section">
        {sacredBecomingOracleDeckContent.map(({ artwork, artworkAlt }) => (
          <div class="sacred-oracle">
            <div class="sacred-oracle-art">
              <img src={artwork} alt={artworkAlt} width="1085" height="1535" loading="lazy" decoding="async" />
            </div>
            <div class="sacred-oracle-copy">
              <p class="sacred-oracle-eyebrow">COMING SOON</p>
              <h2>The Sacred Becoming Oracle</h2>
              <p>I created this oracle deck while walking my own path of becoming. It was my companion. Now it's my gift to you.</p>
              <p>A companion for reflection, ritual, intuition, and the quiet conversations that continue long after the cards are put away.</p>
              <OracleWaitlist />
            </div>
          </div>
        ))}
      </section>
    )}

  </div>

</Base>
