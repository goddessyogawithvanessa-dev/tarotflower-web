---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const recentPosts = posts
  .filter(p => p.data.content_type === 'post')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);

const majorArcana = [
  { name: 'The Fool', slug: 'the-fool-tarot' },
  { name: 'The Magician', slug: 'the-magician-tarot' },
  { name: 'The High Priestess', slug: 'the-high-priestess-tarot' },
  { name: 'The Empress', slug: 'the-empress-tarot' },
  { name: 'The Emperor', slug: 'the-emperor-tarot' },
  { name: 'The Hierophant', slug: 'the-hierophant-tarot' },
  { name: 'The Lovers', slug: 'the-lovers-tarot' },
  { name: 'The Chariot', slug: 'the-chariot-tarot' },
  { name: 'Strength', slug: 'strength-tarot' },
  { name: 'The Hermit', slug: 'the-hermit-tarot' },
  { name: 'The Wheel of Fortune', slug: 'the-wheel-of-fortune-tarot' },
  { name: 'Justice', slug: 'justice-tarot' },
  { name: 'The Hanged Man', slug: 'the-hanged-man-tarot' },
  { name: 'Death', slug: 'death-tarot' },
  { name: 'Temperance', slug: 'temperance-tarot' },
  { name: 'The Devil', slug: 'the-devil-tarot' },
  { name: 'The Tower', slug: 'the-tower-tarot' },
  { name: 'The Star', slug: 'the-star-tarot' },
  { name: 'The Moon', slug: 'the-moon-tarot' },
  { name: 'The Sun', slug: 'the-sun-tarot' },
  { name: 'Judgement', slug: 'judgement-tarot' },
  { name: 'The World', slug: 'the-world-tarot' },
];

const suitImg = '/images/2020/12/IMG_20201215_123548-scaled.jpg';
const suits = [
  { name: 'Pentacles', slug: 'pentacles-tarot', img: suitImg, cards: ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] },
  { name: 'Wands', slug: 'wands-tarot', img: suitImg, cards: ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] },
  { name: 'Swords', slug: 'swords-tarot', img: suitImg, cards: ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] },
  { name: 'Cups', slug: 'cups-tarot', img: suitImg, cards: ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] },
];

function cardSlug(rank: string, suit: string) {
  return `${rank.toLowerCase()}-of-${suit.toLowerCase()}-tarot`;
}
---
<Base title="Tarot Flower – Learn Tarot Online with Meaningful Insight" description="A modern guide to learn tarot online! Discover intuitive card meanings, spreads, rituals, and spiritual wisdom through the sacred art of tarot.">
  <div class="container homepage">

    <section class="hero">
      <h1>Tarot Flower</h1>
      <h2>Unlock the Magic of Tarot, Astrology, and Ritual</h2>
      <p>Welcome, beautiful soul. &#10024; You've arrived at Tarot Flower — a sanctuary for seekers, mystics, and modern goddesses who are ready to deepen their connection with tarot, astrology, and spiritual ritual. Whether you're just starting your journey or you've been walking the path for years, this space was created for you to learn tarot online.</p>

      <details class="read-more-toggle">
        <summary>Read More</summary>
        <div class="read-more-content">
          <p>At Tarot Flower, we believe that tarot is more than a tool for prediction. It's a mirror — a sacred language that speaks to your inner world, revealing the energies at play in your life, your relationships, and your soul's evolution. Here, you'll find <strong>free tarot card readings</strong>, crafted with intention and love, designed to support your personal transformation. Each reading is aligned with the moon, the seasons, and the collective energy, helping you tune in and move with purpose.</p>
          <p>This is a space where the mystical becomes practical. You'll find not only readings, but guidance on the <strong>Suit of Swords</strong>, the <strong>Major Arcana</strong>, the <strong>elements of the tarot</strong>, and how these archetypes can help you embody your higher self. The goal here isn't just to learn tarot — it's to <strong>live it.</strong> To let the cards become part of your intuitive toolkit as you awaken your divine feminine wisdom and step into your power.</p>
          <p>You'll also discover rich resources in <strong>astrology</strong>, <strong>psychic development</strong>, and <strong>ritual practices</strong>. From moon phase updates to goddess invocations, Tarot Flower invites you into a rhythm that is ancient and sacred — yet grounded in your daily reality. Here, we walk with the moon, move with intention, and use magic as medicine.</p>
          <p>Our approach is gentle and inclusive. You don't need to identify as a witch or know all 78 cards to belong here. You just need a curious heart, a willingness to listen to your intuition, and the desire to return home to yourself. Through ritual, reflection, and embodiment, Tarot Flower invites you to remember who you truly are.</p>
          <p>And if you're ready to go deeper, you're invited to join the <strong>Moonlight Circle</strong> — our heart-centered sister community for live circles, deep practices, and goddess embodiment. This is where the virtual space becomes real connection. Where you don't just read the cards — you live them.</p>
          <p>Thank you for being here. Your presence is sacred. Your path is your power. And this — this is just the beginning.</p>
          <p>Welcome to the craft.<br />Welcome to the journey.<br />Welcome home.</p>
        </div>
      </details>
    </section>

    <section class="arcana-section">
      <h2>The Major Arcana</h2>
      <h3 class="arcana-subtitle">The great archetypes of the Tarot</h3>
      <div class="arcana-layout">
        <div class="arcana-left">
          <img src="/images/2021/01/Major-Arcana-e1610542977417.jpg" alt="The Major Arcana tarot cards" />
        </div>
        <div class="arcana-right">
          {majorArcana.map(card => (
            <a href={`/${card.slug}`}>{card.name}</a>
          ))}
        </div>
      </div>
    </section>

    <section class="arcana-section">
      <h2>The Minor Arcana</h2>
      <h3 class="arcana-subtitle">The four suits of the Tarot</h3>
      <div class="suits-grid">
        {suits.map(suit => (
          <div class="suit-col">
            <h3 class="suit-title"><a href={`/${suit.slug}`}>{suit.name}</a></h3>
            <a href={`/${suit.slug}`} class="suit-img-link">
              <img src={suit.img} alt={`${suit.name} tarot cards`} loading="lazy" />
            </a>
            <div class="suit-cards">
              {suit.cards.map(rank => (
                <a href={`/${cardSlug(rank, suit.name)}`}>{rank} of {suit.name}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="recent-posts">
      <h2>Recent from the Journal</h2>
      <div class="posts-grid">
        {recentPosts.map(post => (
          <a href={`/${post.data.slug}`} class="post-card">
            <h3>{post.data.title}</h3>
            <span class="post-date">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </a>
        ))}
      </div>
    </section>

  </div>
</Base>
