---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const posts = await getCollection('posts');
const page = posts.find(p => p.data.slug === 'moon-magic-spells');

let PageContent: any = null;
if (page) {
  const rendered = await render(page);
  PageContent = rendered.Content;
}

const cardSlugs = [
  'music-for-ritual-and-meditationmoon-magic-for-the-full-moon-in-virgo-2023',
  'moon-magic-love-spells-for-your-twin-flame-soul-mate-and-lover',
  'how-to-make-a-moon-magic-altar-for-rituals',
  'lunar-eclipse-rituals-for-the-divine-feminine',
  'moon-magic',
];

const cardPosts = cardSlugs
  .map(slug => posts.find(p => p.data.slug === slug))
  .filter(Boolean);

function extractImage(body: string): string {
  const match = body.match(/!\[([^\]]*)\]\(([^)]+)\)/);
  return match ? match[2] : '';
}

function extractExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#') || trimmed.startsWith('!') || trimmed.startsWith('*') && trimmed.length < 30) continue;
    const clean = trimmed.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/\*\*([^*]+)\*\*/g, '$1').replace(/\*([^*]+)\*/g, '$1');
    if (clean.length > 30) return clean.length > 120 ? clean.slice(0, 117) + '...' : clean;
  }
  return '';
}

const fallbackImages: Record<string, string> = {
  'music-for-ritual-and-meditationmoon-magic-for-the-full-moon-in-virgo-2023': '/images/2023/03/Screen-Shot-2023-03-06-at-3.43.13-PM-400x250.jpg',
};

function formatCategories(cats: string[]): string {
  return cats.map(c => c.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')).join(', ');
}
---
<Base
  title={page?.data.seo_title || 'Moon Magic – Ritual and Practice'}
  description={page?.data.seo_description || ''}
>
  <div class="container">
    <div class="content clearfix">
      {PageContent && <PageContent />}
    </div>

    <section class="zodiac-grid">
      {cardPosts.map(post => {
        const img = fallbackImages[post!.data.slug] || extractImage(post!.body || '');
        const excerpt = extractExcerpt(post!.body || '');
        const displayDate = new Date(post!.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        const cats = post!.data.categories || [];
        return (
          <a href={`/${post!.data.slug}`} class="zodiac-card">
            {img && <div class="zodiac-img"><img src={img} alt={post!.data.title} loading="lazy" /></div>}
            <div class="zodiac-info">
              <h3>{post!.data.title}</h3>
              <span class="zodiac-meta">by Vanessa Hylande | {displayDate} | {formatCategories(cats)}</span>
              {excerpt && <p class="zodiac-excerpt">{excerpt}</p>}
            </div>
          </a>
        );
      })}
    </section>
  </div>
  <script>
    const content = document.querySelector('.content.clearfix');
    const grid = document.querySelector('.zodiac-grid');
    if (content && grid) {
      const paragraphs = content.querySelectorAll('p');
      for (const p of paragraphs) {
        if (p.textContent?.includes('spiritual healing and inner growth')) {
          const afterNodes: Node[] = [];
          let found = false;
          for (const child of Array.from(content.childNodes)) {
            if (found) afterNodes.push(child);
            if (child === p || child.contains?.(p)) found = true;
          }
          if (afterNodes.length > 0) {
            const afterDiv = document.createElement('div');
            afterDiv.className = 'content clearfix';
            for (const node of afterNodes) afterDiv.appendChild(node);
            content.parentNode?.insertBefore(grid, content.nextSibling);
            grid.parentNode?.insertBefore(afterDiv, grid.nextSibling);
          } else {
            content.parentNode?.insertBefore(grid, content.nextSibling);
          }
          break;
        }
      }
    }
  </script>
</Base>
