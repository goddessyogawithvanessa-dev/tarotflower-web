---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const posts = await getCollection('posts');
const page = posts.find(p => p.data.slug === 'moon-magic-spells');

let PageContent: any = null;
if (page) {
  const rendered = await render(page);
  PageContent = rendered.Content;
}

const cardSlugs = [
  'music-for-ritual-and-meditationmoon-magic-for-the-full-moon-in-virgo-2023',
  'moon-magic-love-spells-for-your-twin-flame-soul-mate-and-lover',
  'how-to-make-a-moon-magic-altar-for-rituals',
  'lunar-eclipse-rituals-for-the-divine-feminine',
  'moon-magic',
];

const cardPosts = cardSlugs
  .map(slug => posts.find(p => p.data.slug === slug))
  .filter(Boolean);

function extractImage(body: string): string {
  const match = body.match(/!\[([^\]]*)\]\(([^)]+)\)/);
  return match ? match[2] : '';
}

function extractExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#') || trimmed.startsWith('!') || trimmed.startsWith('*') && trimmed.length < 30) continue;
    const clean = trimmed.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/\*\*([^*]+)\*\*/g, '$1').replace(/\*([^*]+)\*/g, '$1');
    if (clean.length > 30) return clean.length > 120 ? clean.slice(0, 117) + '...' : clean;
  }
  return '';
}

const fallbackImages: Record<string, string> = {
  'music-for-ritual-and-meditationmoon-magic-for-the-full-moon-in-virgo-2023': '/images/2023/03/Screen-Shot-2023-03-06-at-3.43.13-PM-400x250.jpg',
};

function formatCategories(cats: string[]): string {
  return cats.map(c => c.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')).join(', ');
}
---
<Base
  title={page?.data.seo_title || 'Moon Magic – Ritual and Practice'}
  description={page?.data.seo_description || ''}
>
  <div class="container moon-magic-landing">
    <div class="content clearfix moon-magic-content">
      {PageContent && <PageContent />}
    </div>

    <section class="zodiac-grid moon-magic-articles" aria-label="Moon Magic articles">
      {cardPosts.map(post => {
        const img = fallbackImages[post!.data.slug] || extractImage(post!.body || '');
        const excerpt = extractExcerpt(post!.body || '');
        const displayDate = new Date(post!.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        const cats = post!.data.categories || [];
        return (
          <a href={`/${post!.data.slug}`} class="zodiac-card">
            {img && <div class="zodiac-img"><img src={img} alt={post!.data.title} loading="lazy" /></div>}
            <div class="zodiac-info">
              <h3>{post!.data.title}</h3>
              <span class="zodiac-meta">by Vanessa Hylande | {displayDate} | {formatCategories(cats)}</span>
              {excerpt && <p class="zodiac-excerpt">{excerpt}</p>}
            </div>
          </a>
        );
      })}
    </section>

    <details class="moon-magic-accordion">
      <summary>Explore Moon Magic</summary>
      <div class="moon-magic-accordion-shell">
        <div class="moon-magic-longform content clearfix"></div>
      </div>
    </details>

    <section class="ritual-collection" aria-labelledby="digital-rituals-title">
      <div class="ritual-collection-intro">
        <h2 id="digital-rituals-title">Digital Rituals</h2>
        <p class="ritual-collection-lead">Some rituals are meant to be read.</p>
        <p class="ritual-collection-lead">Others are meant to be lived.</p>
        <p>Digital Rituals are immersive guided experiences designed to help you slow down, reconnect with yourself, and embody the wisdom of each element. Through movement, meditation, music, reflection, ritual, and intentional practice, each journey invites you to experience transformation rather than simply read about it.</p>
        <p class="ritual-collection-invitation">Choose the element calling you today.</p>
      </div>

      <div class="ritual-collection-grid">
        <article class="ritual-collection-item ritual-collection-item--fire">
          <a class="ritual-collection-image" href="/step-into-the-fire">
            <img src="/images/digital-rituals/step-into-the-fire/elemental-rituals-header.jpg" alt="Fire goddess beneath a golden moon, surrounded by flames and flowers" loading="lazy" />
          </a>
          <div class="ritual-collection-copy">
            <h3>Step Into the Fire</h3>
            <p>Awaken your courage, reclaim your strength, and ignite the spark that has always lived within you.</p>
            <a class="digital-ritual-button" href="/step-into-the-fire">Ignite</a>
          </div>
        </article>

        <article class="ritual-collection-item ritual-collection-item--water ritual-collection-item--text-first">
          <a class="ritual-collection-image" href="/flow-like-the-goddess">
            <img src="/images/digital-rituals/flow-like-the-goddess/water-goddess-banner-ritual.jpg" alt="Water goddess flowing beneath the moon among golden flowers and fish" loading="lazy" />
          </a>
          <div class="ritual-collection-copy">
            <h3>Flow with the Goddess</h3>
            <p>A gentle invitation to soften, receive, heal, and return to the wisdom of your heart.</p>
            <a class="digital-ritual-button" href="/flow-like-the-goddess">Flow</a>
          </div>
        </article>

        <article class="ritual-collection-item ritual-collection-item--air ritual-collection-item--text-first">
          <a class="ritual-collection-image" href="/awaken-the-element-of-air">
            <img src="/images/digital-rituals/awaken-the-element-of-air/air-goddess-header-web.jpg" alt="Air goddess with luminous wings beneath a golden sky" loading="lazy" />
          </a>
          <div class="ritual-collection-copy">
            <h3>Awaken the Element of Air</h3>
            <p>Create space for clarity, reconnect with your authentic voice, and deepen your connection to your intuition.</p>
            <a class="digital-ritual-button" href="/awaken-the-element-of-air">Breathe</a>
          </div>
        </article>

        <article class="ritual-collection-item ritual-collection-item--earth">
          <a class="ritual-collection-image" href="/root-into-the-earth">
            <img src="/images/digital-rituals/root-into-the-earth/earth-goddess-banner.jpg" alt="Earth goddess beneath the moon in a dark enchanted forest" loading="lazy" />
          </a>
          <div class="ritual-collection-copy">
            <h3>Root Into the Earth</h3>
            <p>Slow down, ground your energy, and remember the steady foundation that supports your becoming.</p>
            <a class="digital-ritual-button" href="/root-into-the-earth">Ground</a>
          </div>
        </article>
      </div>
    </section>
  </div>
  <script>
    const content = document.querySelector('.moon-magic-content');
    const longform = document.querySelector('.moon-magic-longform');
    if (content && longform) {
      const paragraphs = content.querySelectorAll('p');
      for (const p of paragraphs) {
        if (p.textContent?.includes('spiritual healing and inner growth')) {
          const boundary = Array.from(content.children).find(child => child === p || child.contains(p));
          if (boundary) {
            let node = boundary.nextSibling;
            while (node) {
              const next = node.nextSibling;
              longform.appendChild(node);
              node = next;
            }
          }
          break;
        }
      }
    }
  </script>
</Base>
